programa {
  funcao inicio() {
    inteiro numeroA, numeroB
  escreva("escreva o primeiro numero:\n")
  leia (numeroA)
  escreva("escreva o segundo numero:\n")
  leia (numeroB)
  se(numeroA>numeroB){escreva("numero A é maior\n" + numeroA)}senao{se(numeroB>numeroA){escreva("numero B é maior: " + numeroB)}}
  }
}
